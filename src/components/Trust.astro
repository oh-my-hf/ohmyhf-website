---
import { REPO_URL } from '../config';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const repoPath = REPO_URL.replace('https://github.com/', '');

const columns = [
  {
    title: t('trust.openSource.title'),
    description: t('trust.openSource.description'),
    href: REPO_URL,
  },
  {
    title: t('trust.privacy.title'),
    description: t('trust.privacy.description'),
    href: null as string | null,
  },
  {
    title: t('trust.crossPlatform.title'),
    description: t('trust.crossPlatform.description'),
    href: null as string | null,
  },
] as const;
---

<section
  class="border-line bg-panel border-b px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('trust.region')}
>
  <div class="mx-auto max-w-6xl">
    <header class="max-w-xl">
      {/* The one mono device on the page: the repo path, in the Hub's own dialect. */}
      <a
        href={REPO_URL}
        class="text-fog hover:text-iris inline-flex min-h-11 items-center font-mono text-xs transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        {repoPath}
      </a>
      <h2
        class="font-display text-paper mt-1 text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        {t('trust.title')}
      </h2>
    </header>

    <ul class="mt-12 grid gap-10 sm:grid-cols-3 sm:gap-8">
      {
        columns.map((col) => (
          <li>
            <h3 class="font-display text-paper text-lg font-semibold tracking-tight">
              {col.href ? (
                <a
                  href={col.href}
                  class="hover:text-iris transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {col.title}
                </a>
              ) : (
                col.title
              )}
            </h3>
            <p class="text-body mt-3 text-sm leading-relaxed">{col.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
