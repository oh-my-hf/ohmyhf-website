---
const sidebarItems = [
    {
      id: 'models',
      label: 'Models',
      active: true,
      icon: 'M4 6h16M4 12h16M4 18h10',
    },
    {
      id: 'datasets',
      label: 'Datasets',
      active: false,
      icon: 'M4 7v10a2 2 0 002 2h12a2 2 0 002-2V7M4 7l8-3 8 3M4 7l8 3 8-3',
    },
    {
      id: 'spaces',
      label: 'Spaces',
      active: false,
      icon: 'M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z',
    },
    {
      id: 'papers',
      label: 'Papers',
      active: false,
      icon: 'M7 4h10a1 1 0 011 1v14l-6-3-6 3V5a1 1 0 011-1z',
    },
    {
      id: 'downloads',
      label: 'Downloads',
      active: false,
      icon: 'M12 4v10m0 0l-4-4m4 4l4-4M5 18h14',
    },
    {
      id: 'cache',
      label: 'Cache',
      active: false,
      icon: 'M4 7a2 2 0 012-2h12a2 2 0 012 2v2H4V7zm0 4h16v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6z',
    },
  ] as const;

  const models = [
    {
      id: 'llama',
      name: 'meta-llama/Llama-3.1-8B',
      task: 'text-generation',
      downloads: '2.1M',
      likes: '4.8k',
      selected: true,
    },
    {
      id: 'qwen',
      name: 'Qwen/Qwen2.5-7B-Instruct',
      task: 'text-generation',
      downloads: '1.4M',
      likes: '3.2k',
      selected: false,
    },
    {
      id: 'mistral',
      name: 'mistralai/Mistral-7B-v0.3',
      task: 'text-generation',
      downloads: '980k',
      likes: '2.7k',
      selected: false,
    },
    {
      id: 'deepseek',
      name: 'deepseek-ai/DeepSeek-R1',
      task: 'text-generation',
      downloads: '1.8M',
      likes: '5.1k',
      selected: false,
    },
    {
      id: 'gemma',
      name: 'google/gemma-2-9b',
      task: 'text-generation',
      downloads: '720k',
      likes: '1.9k',
      selected: false,
    },
    {
      id: 'whisper',
      name: 'openai/whisper-large-v3',
      task: 'automatic-speech-recognition',
      downloads: '3.4M',
      likes: '6.2k',
      selected: false,
    },
  ] as const;

  const files = [
    { name: 'config.json', size: '1.2 KB' },
    { name: 'model.safetensors', size: '16.1 GB' },
    { name: 'tokenizer.json', size: '17.2 MB' },
    { name: 'tokenizer_config.json', size: '4.1 KB' },
    { name: 'generation_config.json', size: '184 B' },
  ] as const;
---
<!-- PLACEHOLDER: replace with real screenshot hero-app-window.png (recommended 2560×1600 @2x) when available -->

<div
  class="theme-dark hero-enter mx-auto w-full max-w-5xl"
  style="aspect-ratio: 16 / 10;"
  aria-hidden="true"
>
  <div
    class="h-full w-full overflow-hidden rounded-lg border border-line bg-panel shadow-[0_24px_80px_-12px_rgba(0,0,0,0.65)] [transform:perspective(1400px)_rotateX(1.5deg)]"
  >
    <!-- Title bar -->
    <div
      class="flex h-9 shrink-0 items-center gap-2 border-b border-line px-3"
    >
      <span class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#FEBC2E]"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-[#28C840]"></span>
      <span
        class="ml-3 truncate font-mono text-[10px] tracking-wide text-fog"
      >
        ohmyhf — Models
      </span>
    </div>

    <!-- Three panes -->
    <div class="grid h-[calc(100%-2.25rem)] grid-cols-[3.5rem_1fr] sm:grid-cols-[8.5rem_1fr] lg:grid-cols-[9.5rem_minmax(0,1.15fr)_minmax(0,1fr)]">
      <!-- Sidebar -->
      <aside class="flex flex-col gap-0.5 border-r border-line bg-ink/40 p-1.5 sm:p-2">
        {
          sidebarItems.map((item) => (
            <div
              class:list={[
                'flex items-center gap-2 rounded-sm px-1.5 py-1.5 sm:px-2',
                item.active
                  ? 'bg-iris/15 text-paper'
                  : 'text-fog',
              ]}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                class="h-3.5 w-3.5 shrink-0"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
              <span class="hidden truncate font-mono text-[10px] sm:inline">
                {item.label}
              </span>
            </div>
          ))
        }
      </aside>

      <!-- Model list -->
      <div class="relative min-w-0 overflow-hidden border-r border-line lg:border-r">
        <div
          class="flex h-8 items-center justify-between border-b border-line px-3"
        >
          <span class="font-mono text-[10px] uppercase tracking-wider text-fog">
            Models
          </span>
          <span class="font-mono text-[10px] text-fog">6 shown</span>
        </div>
        <ul class="absolute inset-x-0 top-8 bottom-0 overflow-hidden">
          {
            models.map((model) => (
              <li
                class:list={[
                  'border-b border-line/60 px-3 py-2.5',
                  model.selected
                    ? 'bg-iris/10'
                    : 'bg-transparent',
                ]}
              >
                <div class="truncate font-mono text-[11px] text-paper">
                  {model.name}
                </div>
                <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5">
                  <span class="rounded-sm bg-line/80 px-1.5 py-0.5 font-mono text-[9px] text-fog">
                    {model.task}
                  </span>
                  <span class="font-mono text-[9px] text-fog">
                    {model.downloads} dl
                  </span>
                  <span class="font-mono text-[9px] text-fog">
                    {model.likes} likes
                  </span>
                </div>
              </li>
            ))
          }
        </ul>
        <!-- Scroll fade hint -->
        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-panel to-transparent"
        >
        </div>
      </div>

      <!-- Preview pane -->
      <div class="hidden min-w-0 overflow-hidden lg:flex lg:flex-col">
        <div
          class="flex h-8 items-center border-b border-line px-3"
        >
          <span class="truncate font-mono text-[10px] text-fog">
            meta-llama/Llama-3.1-8B
          </span>
        </div>
        <div class="flex-1 overflow-hidden p-3">
          <div class="space-y-2">
            <h3 class="font-display text-sm font-semibold text-paper">
              Llama 3.1 8B
            </h3>
            <p class="text-[10px] leading-relaxed text-fog">
              Meta Llama 3.1 is a collection of pretrained and instruction-tuned
              generative models. Optimized for dialogue and multilingual use.
            </p>
            <div
              class="overflow-hidden rounded-sm border border-line bg-ink/50"
            >
              <table class="w-full font-mono text-[9px]">
                <tbody>
                  <tr class="border-b border-line/80">
                    <td class="px-2 py-1 text-fog">License</td>
                    <td class="px-2 py-1 text-[#7BA3C9]">llama3.1</td>
                  </tr>
                  <tr class="border-b border-line/80">
                    <td class="px-2 py-1 text-fog">Params</td>
                    <td class="px-2 py-1 text-[#8FBF9A]">8B</td>
                  </tr>
                  <tr>
                    <td class="px-2 py-1 text-fog">Library</td>
                    <td class="px-2 py-1 text-[#C9A87B]">transformers</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <pre
              class="overflow-hidden rounded-sm border border-line bg-ink/50 p-2 font-mono text-[9px] leading-relaxed text-[#8FBF9A]"
            ><code>{`from transformers import pipeline
pipe = pipeline("text-generation",
  model="meta-llama/Llama-3.1-8B")`}</code></pre>
          </div>
          <div class="mt-3 border-t border-line pt-2">
            <div
              class="mb-1.5 font-mono text-[9px] uppercase tracking-wider text-fog"
            >
              Files
            </div>
            <ul class="space-y-0.5">
              {
                files.map((file) => (
                  <li class="flex items-center justify-between gap-2 font-mono text-[9px]">
                    <span class="truncate text-[#7BA3C9]">{file.name}</span>
                    <span class="shrink-0 text-fog">{file.size}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
