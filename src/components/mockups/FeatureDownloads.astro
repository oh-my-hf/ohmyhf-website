---
const jobs = [
    {
      name: 'model-00001-of-00004.safetensors',
      status: 'progress' as const,
      pct: 72,
      speed: '24.6 MB/s',
    },
    {
      name: 'model-00002-of-00004.safetensors',
      status: 'paused' as const,
      pct: 41,
      speed: 'Paused',
    },
    {
      name: 'model-00003-of-00004.safetensors',
      status: 'verifying' as const,
      pct: 100,
      speed: 'sha256…',
    },
    {
      name: 'tokenizer.json',
      status: 'done' as const,
      pct: 100,
      speed: 'Done',
    },
  ] as const;
---
<!-- PLACEHOLDER: replace with real screenshot feature-downloads.png (recommended 2560×1600 @2x) when available -->

<div
  class="theme-dark feature-reveal w-full overflow-hidden rounded-lg border border-line bg-panel shadow-[0_16px_48px_-16px_rgba(0,0,0,0.55)]"
  style="aspect-ratio: 16 / 11;"
  aria-hidden="true"
>
  <div class="flex h-8 items-center justify-between border-b border-line px-3">
    <div class="flex items-center gap-1.5">
      <span class="h-2 w-2 rounded-full bg-[#FF5F57]"></span>
      <span class="h-2 w-2 rounded-full bg-[#FEBC2E]"></span>
      <span class="h-2 w-2 rounded-full bg-[#28C840]"></span>
      <span class="ml-2 font-mono text-[10px] text-fog">Downloads</span>
    </div>
    <span class="font-mono text-[9px] text-fog">4 in queue</span>
  </div>
  <ul class="divide-y divide-line/60 p-2 sm:p-3">
    {
      jobs.map((job) => (
        <li class="px-1 py-2.5 sm:px-2">
          <div class="flex items-center justify-between gap-2">
            <span class="min-w-0 truncate font-mono text-[10px] text-paper">
              {job.name}
            </span>
            <span
              class:list={[
                'shrink-0 font-mono text-[9px]',
                job.status === 'done'
                  ? 'text-jade'
                  : job.status === 'paused'
                    ? 'text-fog'
                    : job.status === 'verifying'
                      ? 'text-[#C9A87B]'
                      : 'text-fog',
              ]}
            >
              {job.status === 'done' ? (
                <span class="inline-flex items-center gap-1">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 16 16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="h-3 w-3"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3.5 8.5l3 3 6-6"
                    />
                  </svg>
                  {job.speed}
                </span>
              ) : (
                job.speed
              )}
            </span>
          </div>
          <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-line">
            <div
              class:list={[
                'h-full rounded-full',
                job.status === 'done'
                  ? 'bg-jade'
                  : job.status === 'paused'
                    ? 'bg-fog/40'
                    : job.status === 'verifying'
                      ? 'bg-[#C9A87B]/70'
                      : 'bg-jade',
              ]}
              style={`width: ${job.pct}%`}
            >
            </div>
          </div>
          <div class="mt-1 font-mono text-[9px] text-fog">
            {job.pct}%
            {job.status === 'verifying' ? ' · verifying sha256' : ''}
            {job.status === 'paused' ? ' · paused' : ''}
          </div>
        </li>
      ))
    }
  </ul>
</div>
