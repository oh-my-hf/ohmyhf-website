---
const repos = [
    { name: 'models--meta-llama--Llama-3.1-8B', size: '64.2 GB', pct: 100 },
    { name: 'models--Qwen--Qwen2.5-72B', size: '142.8 GB', pct: 100 },
    { name: 'models--mistralai--Mistral-7B', size: '28.4 GB', pct: 44 },
    { name: 'models--openai--whisper-large-v3', size: '18.1 GB', pct: 28 },
    { name: 'datasets--allenai--c4', size: '41.6 GB', pct: 65 },
  ] as const;
---
<!-- PLACEHOLDER: replace with real screenshot feature-cache.png (recommended 2560×1600 @2x) when available -->

<div
  class="feature-reveal w-full overflow-hidden rounded-lg border border-line bg-panel shadow-[0_16px_48px_-16px_rgba(0,0,0,0.55)]"
  style="aspect-ratio: 16 / 11;"
  aria-hidden="true"
>
  <div class="flex h-8 items-center justify-between border-b border-line px-3">
    <div class="flex items-center gap-1.5">
      <span class="h-2 w-2 rounded-full bg-[#FF5F57]"></span>
      <span class="h-2 w-2 rounded-full bg-[#FEBC2E]"></span>
      <span class="h-2 w-2 rounded-full bg-[#28C840]"></span>
      <span class="ml-2 font-mono text-[10px] text-fog">Cache</span>
    </div>
    <span class="font-mono text-[10px] text-paper">312.4 GB</span>
  </div>
  <div class="flex h-[calc(100%-2rem)] flex-col p-3 sm:p-4">
    <div class="mb-3 flex items-baseline justify-between gap-2">
      <span class="font-mono text-[10px] uppercase tracking-wider text-fog">
        Disk by repo
      </span>
      <span class="font-mono text-[10px] text-fog">~/.cache/huggingface</span>
    </div>
    <ul class="min-h-0 flex-1 space-y-2.5 overflow-hidden">
      {
        repos.map((repo) => (
          <li>
            <div class="mb-1 flex items-center justify-between gap-2">
              <span class="min-w-0 truncate font-mono text-[9px] text-paper sm:text-[10px]">
                {repo.name}
              </span>
              <span class="shrink-0 font-mono text-[9px] text-fog">
                {repo.size}
              </span>
            </div>
            <div class="h-1.5 overflow-hidden rounded-full bg-line">
              <div
                class="h-full rounded-full bg-iris/70"
                style={`width: ${repo.pct}%`}
              >
              </div>
            </div>
          </li>
        ))
      }
    </ul>
    <div
      class="mt-3 flex items-center justify-between gap-2 rounded-sm border border-line bg-ink/50 px-2.5 py-2"
    >
      <span class="font-mono text-[9px] text-fog sm:text-[10px]">
        2 stale revisions · Reclaim 28.6 GB
      </span>
      <span
        class="shrink-0 rounded-sm bg-jade/15 px-2 py-0.5 font-mono text-[9px] text-jade"
      >
        Clean up
      </span>
    </div>
  </div>
</div>
