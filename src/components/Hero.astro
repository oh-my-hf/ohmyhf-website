---
import { Image } from 'astro:assets';
import { REPO_URL, released, version } from '../config';
import { useTranslations, type Locale } from '../i18n';
import browseLight from '../assets/images/browse.png';
import browseDark from '../assets/images/browse-dark.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const primaryHref = released ? '#download' : REPO_URL;
const primaryExternal = !released;
---

<section
  id="hero"
  data-hero
  class="relative overflow-hidden border-b border-line px-4 pb-16 pt-24 sm:px-6 sm:pb-24 sm:pt-28"
  aria-label={t('hero.region')}
>
  <div
    class="pointer-events-none absolute inset-0 site-wash"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <div
        data-hero-brand
        class="mb-6 flex items-center justify-center gap-3 will-change-transform"
      >
        <img
          src={`${base}/favicon.png`}
          alt=""
          width="48"
          height="48"
          class="h-12 w-12 rounded-full"
        />
        <span class="font-display text-xl font-semibold tracking-tight text-paper"
          >ohmyhf</span
        >
        <span
          class="rounded-full border border-line bg-panel px-2.5 py-0.5 font-mono text-[11px] font-medium tracking-wide text-faint uppercase"
        >
          {t('hero.unofficial')}
        </span>
      </div>

      <h1
        data-hero-title
        class="font-display text-3xl font-semibold tracking-tight text-paper will-change-transform sm:text-4xl md:text-5xl md:leading-[1.12]"
        style="letter-spacing: -0.03em"
      >
        {t('hero.title')}
      </h1>
      <p
        data-hero-sub
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-body will-change-transform sm:text-lg"
      >
        {t('hero.subtitle')}
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          data-hero-cta
          href={primaryHref}
          class="btn-primary will-change-transform"
          {...(primaryExternal
            ? { target: '_blank', rel: 'noopener noreferrer' }
            : {})}
        >
          {t('hero.ctaPrimary')}
        </a>
        <a
          data-hero-cta
          href={REPO_URL}
          class="btn-secondary will-change-transform"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.26.82-.577 0-.285-.01-1.04-.016-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.76-1.605-2.665-.304-5.466-1.332-5.466-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.235 1.91 1.235 3.22 0 4.61-2.807 5.624-5.48 5.92.43.37.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .32.216.694.825.576C20.565 21.796 24 17.297 24 12 24 5.37 18.63 0 12 0z"
            ></path>
          </svg>
          {t('hero.ctaSecondary')}
        </a>
      </div>

      <p
        data-hero-meta
        class="mt-5 font-mono text-[11px] leading-relaxed tracking-wide text-faint will-change-transform sm:text-xs"
      >
        {
          released
            ? t('hero.badgeReleased').replace('{version}', version)
            : t('hero.badge')
        }
      </p>
    </div>

    <div class="mt-12 sm:mt-16">
      <figure
        data-hero-shot
        class="shot-frame mx-auto max-w-5xl will-change-transform"
      >
        <Image
          src={browseLight}
          alt={t('hero.shotAlt')}
          width={1024}
          height={640}
          class="shot-light h-auto w-full"
          priority
        />
        <Image
          src={browseDark}
          alt={t('hero.shotAlt')}
          width={1024}
          height={640}
          class="shot-dark h-auto w-full"
          priority
        />
      </figure>
    </div>
  </div>
</section>
