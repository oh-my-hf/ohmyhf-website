---
import { REPO_URL } from '../config';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const contributingHref = `${REPO_URL}/blob/main/CONTRIBUTING.md`;

const items = [
  {
    q: t('faq.items.official.q'),
    a: t('faq.items.official.a'),
    link: null as string | null,
  },
  {
    q: t('faq.items.free.q'),
    a: t('faq.items.free.a'),
    link: null as string | null,
  },
  {
    q: t('faq.items.safety.q'),
    a: t('faq.items.safety.a'),
    link: null as string | null,
  },
  {
    q: t('faq.items.platforms.q'),
    a: t('faq.items.platforms.a'),
    link: null as string | null,
  },
  {
    q: t('faq.items.cache.q'),
    a: t('faq.items.cache.a'),
    link: null as string | null,
  },
  {
    q: t('faq.items.contribute.q'),
    a: t('faq.items.contribute.a'),
    link: contributingHref,
  },
] as const;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<section
  id="faq"
  class="border-line border-b px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('faq.region')}
>
  <div class="mx-auto max-w-6xl">
    <header class="max-w-xl">
      <h2
        class="font-display text-paper text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        {t('faq.title')}
      </h2>
    </header>

    <div class="divide-line border-line mt-12 divide-y border-y">
      {
        items.map((item) => (
          <details class="group py-1">
            <summary class="text-paper hover:text-iris cursor-pointer list-none py-4 pr-8 text-base font-medium transition-colors marker:content-none [&::-webkit-details-marker]:hidden">
              <span class="flex items-start justify-between gap-4">
                <h3 class="contents">{item.q}</h3>
                <span
                  class="text-faint mt-1 shrink-0 font-mono text-xs transition-transform group-open:rotate-45"
                  aria-hidden="true"
                >
                  +
                </span>
              </span>
            </summary>
            <div class="text-body max-w-[70ch] pb-5 text-sm leading-relaxed">
              <p>{item.a}</p>
              {item.link ? (
                <p class="mt-3">
                  <a
                    href={item.link}
                    class="text-paper hover:text-iris underline underline-offset-2 transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {t('faq.contributeLink')}
                  </a>
                </p>
              ) : null}
            </div>
          </details>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
