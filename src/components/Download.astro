---
import { DOWNLOAD_URLS, RELEASES_URL, REPO_URL, released, version } from '../config';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const unsignedHref = `${REPO_URL}/blob/main/docs/signing.md`;
const watchHref = REPO_URL;

const platforms = [
  {
    id: 'macos',
    label: t('download.macos'),
    format: t('download.macosFormat'),
    href: DOWNLOAD_URLS.macOS,
    platform: 'macos',
  },
  {
    id: 'windows',
    label: t('download.windows'),
    format: t('download.windowsFormat'),
    href: DOWNLOAD_URLS.windows,
    platform: 'windows',
  },
  {
    id: 'linux',
    label: t('download.linux'),
    format: t('download.linuxFormat'),
    href: DOWNLOAD_URLS.linuxAppImage,
    platform: 'linux',
    secondaryHref: DOWNLOAD_URLS.linuxDeb,
    secondaryLabel: t('download.linuxDeb'),
  },
] as const;
---

<section
  id="download"
  data-download
  class="border-line border-b px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('download.region')}
>
  <div class="mx-auto max-w-6xl">
    <header data-section-head class="max-w-xl will-change-transform">
      <h2
        class="font-display text-paper text-2xl font-semibold tracking-tight sm:text-3xl"
      >
        {t('download.title')}
      </h2>
      {
        released ? (
          <p class="text-body mt-4 text-sm leading-relaxed">
            {t('download.versionLinePrefix').replace('{version}', version)}{' '}
            <a
              href={RELEASES_URL}
              class="text-paper hover:text-iris underline underline-offset-2 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('download.releasesLink')}
            </a>{' '}
            {t('download.versionLineSuffix')}
          </p>
        ) : (
          <p class="text-body mt-4 text-sm leading-relaxed">{t('download.notice')}</p>
        )
      }
    </header>

    {
      !released && (
        <div class="mt-8">
          <a
            href={watchHref}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('download.watchCta')}
          </a>
        </div>
      )
    }

    <ul class="mt-12 grid gap-4 sm:grid-cols-3" data-download-matrix>
      {
        platforms.map((p) => (
          <li
            class="border-line bg-panel data-[active=true]:border-iris/40 data-[active=true]:bg-ink rounded-lg border p-5 transition-[border-color,background-color] will-change-transform"
            data-platform={p.platform}
            data-download-platform
          >
            <h3 class="font-display text-paper text-lg font-semibold tracking-tight">
              {p.label}
            </h3>
            <p class="text-faint mt-1 font-mono text-[11px]">{p.format}</p>

            {released ? (
              <div class="mt-5 flex flex-col gap-2">
                <a href={p.href} class="download-cta" data-download-primary>
                  {t('download.get')} {p.label}
                </a>
                {'secondaryHref' in p && p.secondaryHref ? (
                  <a
                    href={p.secondaryHref}
                    class="border-line text-fog hover:border-paper/20 hover:text-paper inline-flex items-center justify-center rounded-full border px-4 py-2 font-mono text-xs transition-colors"
                  >
                    {p.secondaryLabel}
                  </a>
                ) : null}
                {p.id === 'macos' ? (
                  <p class="text-fog mt-1 text-xs leading-relaxed">
                    {t('download.unsignedPrefix')}
                    <a
                      href={unsignedHref}
                      class="text-body hover:text-iris underline underline-offset-2 transition-colors"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {t('download.unsignedNote')}
                    </a>
                    {t('download.unsignedSuffix')}
                  </p>
                ) : null}
              </div>
            ) : (
              <div class="mt-5 flex flex-col gap-2">
                <span
                  class="border-line bg-panel-2 text-faint inline-flex cursor-not-allowed items-center justify-center rounded-full border px-4 py-2 text-sm font-medium"
                  aria-disabled="true"
                  role="link"
                  data-download-primary
                >
                  {t('download.comingSoon')}
                </span>
                {'secondaryHref' in p && p.secondaryHref ? (
                  <span
                    class="border-line/60 text-faint inline-flex cursor-not-allowed items-center justify-center rounded-full border px-4 py-2 font-mono text-xs"
                    aria-disabled="true"
                    role="link"
                  >
                    {p.secondaryLabel}
                  </span>
                ) : null}
              </div>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  type Platform = 'macos' | 'windows' | 'linux' | 'unknown';

  function detectPlatform(): Platform {
    const nav = navigator as Navigator & {
      userAgentData?: { platform?: string; getHighEntropyValues?: unknown };
    };
    const uaDataPlatform = nav.userAgentData?.platform?.toLowerCase() ?? '';
    const ua = navigator.userAgent.toLowerCase();
    const platform = (navigator.platform || '').toLowerCase();

    if (
      uaDataPlatform.includes('mac') ||
      platform.includes('mac') ||
      ua.includes('mac os') ||
      ua.includes('macintosh')
    ) {
      return 'macos';
    }
    if (
      uaDataPlatform.includes('win') ||
      platform.includes('win') ||
      ua.includes('windows')
    ) {
      return 'windows';
    }
    if (
      uaDataPlatform.includes('linux') ||
      platform.includes('linux') ||
      (ua.includes('linux') && !ua.includes('android'))
    ) {
      return 'linux';
    }
    return 'unknown';
  }

  const detected = detectPlatform();
  if (detected !== 'unknown') {
    document.querySelectorAll<HTMLElement>('[data-download-platform]').forEach((el) => {
      el.dataset.active = el.dataset.platform === detected ? 'true' : 'false';
    });
  }
</script>
