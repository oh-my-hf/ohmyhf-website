---
import { useTranslations, type Locale } from '../i18n';
import FeatureBrowse from './mockups/FeatureBrowse.astro';
import FeatureCommandPalette from './mockups/FeatureCommandPalette.astro';
import FeatureDownloads from './mockups/FeatureDownloads.astro';
import FeatureCache from './mockups/FeatureCache.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  id="features"
  class="border-b border-line px-4 py-24 sm:px-6 sm:py-32"
  aria-label={t('features.region')}
>
  <div class="mx-auto max-w-6xl space-y-24 sm:space-y-32">
    <!-- 01 Browse -->
    <article class="feature-reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl lg:order-1">
        <p class="font-mono text-xs tracking-wider text-fog">
          <span class="text-iris">{t('features.browse.number')}</span>
          <span class="mx-2 text-line">/</span>
          <span class="uppercase">{t('features.browse.eyebrow')}</span>
        </p>
        <h2
          class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl"
        >
          {t('features.browse.title')}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-fog">
          {t('features.browse.description')}
        </p>
      </div>
      <div class="min-w-0 lg:order-2">
        <FeatureBrowse />
      </div>
    </article>

    <!-- 02 Command -->
    <article class="feature-reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl lg:order-2">
        <p class="font-mono text-xs tracking-wider text-fog">
          <span class="text-iris">{t('features.command.number')}</span>
          <span class="mx-2 text-line">/</span>
          <span class="uppercase">{t('features.command.eyebrow')}</span>
        </p>
        <h2
          class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl"
        >
          {t('features.command.title')}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-fog">
          {t('features.command.description')}
        </p>
      </div>
      <div class="min-w-0 lg:order-1">
        <FeatureCommandPalette />
      </div>
    </article>

    <!-- 03 Downloads -->
    <article class="feature-reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl lg:order-1">
        <p class="font-mono text-xs tracking-wider text-fog">
          <span class="text-iris">{t('features.downloads.number')}</span>
          <span class="mx-2 text-line">/</span>
          <span class="uppercase">{t('features.downloads.eyebrow')}</span>
        </p>
        <h2
          class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl"
        >
          {t('features.downloads.title')}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-fog">
          {t('features.downloads.description')}
        </p>
      </div>
      <div class="min-w-0 lg:order-2">
        <FeatureDownloads />
      </div>
    </article>

    <!-- 04 Cache -->
    <article class="feature-reveal grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl lg:order-2">
        <p class="font-mono text-xs tracking-wider text-fog">
          <span class="text-iris">{t('features.cache.number')}</span>
          <span class="mx-2 text-line">/</span>
          <span class="uppercase">{t('features.cache.eyebrow')}</span>
        </p>
        <h2
          class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl"
        >
          {t('features.cache.title')}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-fog">
          {t('features.cache.description')}
        </p>
      </div>
      <div class="min-w-0 lg:order-1">
        <FeatureCache />
      </div>
    </article>
  </div>
</section>
