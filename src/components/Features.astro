---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { useTranslations, type Locale } from '../i18n';
import browseLight from '../assets/images/browse.png';
import browseDark from '../assets/images/browse-dark.png';
import filterLight from '../assets/images/filter-panel.png';
import filterDark from '../assets/images/filter-panel-dark.png';
import filesLight from '../assets/images/file-preview.png';
import filesDark from '../assets/images/file-preview-dark.png';
import homeLight from '../assets/images/home-feed.png';
import homeDark from '../assets/images/home-feed-dark.png';
import spacesLight from '../assets/images/spaces-gallery.png';
import spacesDark from '../assets/images/spaces-gallery-dark.png';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

/** Each row’s copy is written for the screenshot it shows — keep them paired. */
const features = [
  {
    key: 'browse',
    title: t('features.browse.title'),
    description: t('features.browse.description'),
    src: browseLight,
    srcDark: browseDark as ImageMetadata | null,
    alt: t('features.browse.shotAlt'),
    reverse: false,
  },
  {
    key: 'filter',
    title: t('features.filter.title'),
    description: t('features.filter.description'),
    src: filterLight,
    srcDark: filterDark as ImageMetadata | null,
    alt: t('features.filter.shotAlt'),
    reverse: true,
  },
  {
    key: 'files',
    title: t('features.files.title'),
    description: t('features.files.description'),
    src: filesLight,
    srcDark: filesDark as ImageMetadata | null,
    alt: t('features.files.shotAlt'),
    reverse: false,
  },
  {
    key: 'home',
    title: t('features.home.title'),
    description: t('features.home.description'),
    src: homeLight,
    srcDark: homeDark as ImageMetadata | null,
    alt: t('features.home.shotAlt'),
    reverse: true,
  },
  {
    key: 'spaces',
    title: t('features.spaces.title'),
    description: t('features.spaces.description'),
    src: spacesLight,
    srcDark: spacesDark as ImageMetadata | null,
    alt: t('features.spaces.shotAlt'),
    reverse: false,
  },
] as const;
---

<section
  id="features"
  class="border-line border-b px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('features.region')}
>
  <div class="mx-auto max-w-6xl space-y-20 sm:space-y-28">
    {
      features.map((f) => (
        <article data-feature class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <div
            data-feature-copy
            class:list={['max-w-xl will-change-transform', f.reverse && 'lg:order-2']}
          >
            <h2 class="font-display text-paper text-2xl font-semibold tracking-tight sm:text-3xl">
              {f.title}
            </h2>
            <p class="text-body mt-4 text-base leading-relaxed">{f.description}</p>
          </div>
          <div
            data-feature-shot
            class:list={['min-w-0 will-change-transform', f.reverse && 'lg:order-1']}
          >
            <figure class="shot-frame">
              <Image
                src={f.src}
                alt={f.alt}
                width={800}
                height={500}
                sizes="(min-width: 1024px) 544px, 100vw"
                class:list={[
                  f.srcDark ? 'shot-light' : 'shot-light-only',
                  'h-auto w-full',
                ]}
              />
              {f.srcDark ? (
                <Image
                  src={f.srcDark}
                  alt={f.alt}
                  width={800}
                  height={500}
                  sizes="(min-width: 1024px) 544px, 100vw"
                  class="shot-dark h-auto w-full"
                />
              ) : null}
            </figure>
          </div>
        </article>
      ))
    }
  </div>
</section>
