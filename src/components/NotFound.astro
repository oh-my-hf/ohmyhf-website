---
import BaseLayout from '../layouts/BaseLayout.astro';
import { REPO_URL } from '../config';
import { alternateLocale, localeHref, useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = localeHref(locale);
const alt = alternateLocale(locale);
const altHref = localeHref(alt);
const switchLabel = alt === 'zh-CN' ? t('nav.switchToZh') : t('nav.switchToEn');
---

<BaseLayout
  locale={locale}
  title={t('notFound.metaTitle')}
  description={t('notFound.metaDescription')}
  noIndex
  skipJsonLd
>
  <div data-not-found class="relative flex min-h-screen flex-col overflow-hidden">
    <div class="site-wash pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <header class="site-header border-line/80 relative z-10 border-b backdrop-blur-md">
      <div
        class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6"
      >
        <a
          data-nf-home-link
          href={homeHref}
          class="font-display text-paper hover:text-iris flex items-center gap-2.5 text-lg font-semibold tracking-tight transition-colors"
        >
          <img
            src={`${base}/favicon.png`}
            alt=""
            width="28"
            height="28"
            class="h-7 w-7 rounded-full"
          />
          ohmyhf
        </a>
        <div class="flex items-center gap-3">
          <a
            data-nf-lang
            href={altHref}
            class="text-fog hover:bg-panel-2 hover:text-paper inline-flex min-h-11 items-center rounded-lg px-2 font-mono text-xs transition-colors"
          >
            {switchLabel}
          </a>
          <a
            href={REPO_URL}
            class="text-fog hover:text-paper hidden transition-colors sm:inline-flex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('notFound.github')}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.26.82-.577 0-.285-.01-1.04-.016-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.76-1.605-2.665-.304-5.466-1.332-5.466-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23a11.5 11.5 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.235 1.91 1.235 3.22 0 4.61-2.807 5.624-5.48 5.92.43.37.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .32.216.694.825.576C20.565 21.796 24 17.297 24 12 24 5.37 18.63 0 12 0z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <main
      class="relative z-10 flex flex-1 flex-col items-center justify-center px-4 py-20 sm:px-6 sm:py-28"
    >
      <div class="mx-auto w-full max-w-lg text-center">
        <p
          data-nf-code
          class="text-faint font-mono text-sm font-medium tracking-[0.2em] will-change-transform"
        >
          {t('notFound.code')}
        </p>
        <div
          data-nf-brand
          class="mt-8 flex items-center justify-center gap-3 will-change-transform"
        >
          <img
            src={`${base}/favicon.png`}
            alt=""
            width="56"
            height="56"
            class="h-14 w-14 rounded-full"
          />
        </div>
        <h1
          data-nf-title
          class="font-display text-paper mt-6 text-3xl font-semibold tracking-tight will-change-transform sm:text-4xl"
          style="letter-spacing: -0.03em"
        >
          {t('notFound.title')}
        </h1>
        <p
          data-nf-body
          class="text-body mx-auto mt-4 max-w-md text-base leading-relaxed will-change-transform"
        >
          {t('notFound.body')}
        </p>
        <div
          data-nf-actions
          class="mt-10 flex flex-wrap items-center justify-center gap-3 will-change-transform"
        >
          <a data-nf-cta-home href={homeHref} class="btn-primary">
            {t('notFound.home')}
          </a>
          <a data-nf-cta-download href={`${homeHref}#download`} class="btn-secondary">
            {t('notFound.download')}
          </a>
        </div>
      </div>
    </main>

    <footer class="border-line relative z-10 border-t px-4 py-6 sm:px-6">
      <p
        data-nf-footer
        class="text-faint mx-auto max-w-6xl text-center font-mono text-[11px]"
      >
        {t('footer.notAffiliated')}
      </p>
    </footer>
  </div>
</BaseLayout>

<script>
  import gsap from 'gsap';

  // Content is visible in markup; only a visible tab shortly after load
  // gets the entrance, and a failsafe reverts it if the ticker stalls.
  const root = document.querySelector('[data-not-found]');
  if (root) {
    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      // Checked inside the handler: it can also fire on a later media-query
      // toggle, and must not re-hide a page the visitor is already reading.
      if (document.visibilityState !== 'visible' || performance.now() > 2000) {
        return;
      }

      const code = root.querySelector('[data-nf-code]');
      const brand = root.querySelector('[data-nf-brand]');
      const title = root.querySelector('[data-nf-title]');
      const body = root.querySelector('[data-nf-body]');
      const actions = root.querySelector('[data-nf-actions]');

      gsap.set([code, brand, title, body, actions].filter(Boolean), {
        autoAlpha: 0,
      });
      gsap.set([title, body].filter(Boolean), { y: 20 });
      gsap.set(brand, { scale: 0.9, y: 8 });
      gsap.set(actions, { y: 12 });

      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.to(code, { autoAlpha: 1, duration: 0.4 }, 0.05)
        .to(brand, { autoAlpha: 1, scale: 1, y: 0, duration: 0.5 }, '-=0.15')
        .to(title, { autoAlpha: 1, y: 0, duration: 0.55 }, '-=0.25')
        .to(body, { autoAlpha: 1, y: 0, duration: 0.45 }, '-=0.3')
        .to(actions, { autoAlpha: 1, y: 0, duration: 0.4 }, '-=0.25');

      const failsafe = window.setTimeout(() => {
        if (tl.progress() === 0) {
          mm.revert();
        }
      }, 1200);

      return () => window.clearTimeout(failsafe);
    });
  }
</script>
