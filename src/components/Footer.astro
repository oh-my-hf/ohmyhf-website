---
import { REPO_URL } from '../config';
import { alternateLocale, localeHref, useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const alt = alternateLocale(locale);
const altHref = localeHref(alt);
const switchLabel = alt === 'zh-CN' ? t('nav.switchToZh') : t('nav.switchToEn');

const links = [
  { href: REPO_URL, label: t('footer.github') },
  { href: `${REPO_URL}/releases`, label: t('footer.releases') },
  { href: `${REPO_URL}/blob/main/LICENSE`, label: t('footer.license') },
] as const;
---

<footer class="border-line bg-panel border-t px-4 py-12 sm:px-6 sm:py-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-6 flex items-center gap-3">
      <img
        src={`${base}/favicon.png`}
        alt=""
        width="36"
        height="36"
        loading="lazy"
        class="h-9 w-9 rounded-full"
      />
      <span class="font-display text-paper text-lg font-semibold tracking-tight">
        ohmyhf
      </span>
    </div>

    <p class="text-body max-w-[70ch] text-sm leading-relaxed">
      {t('footer.disclaimer')}
    </p>

    <div
      class="border-line mt-8 flex flex-col gap-6 border-t pt-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <nav
        class="flex flex-wrap items-center gap-x-5 gap-y-2"
        aria-label={t('footer.nav')}
      >
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-fog hover:text-iris inline-flex min-h-11 items-center font-mono text-xs transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={altHref}
          class="text-fog hover:text-iris inline-flex min-h-11 items-center font-mono text-xs transition-colors"
        >
          {switchLabel}
        </a>
      </nav>

      <div class="text-faint flex flex-col gap-1 font-mono text-[11px] sm:items-end">
        <p>{t('footer.notAffiliated')}</p>
        <p>{t('footer.noTrackers')}</p>
      </div>
    </div>
  </div>
</footer>
