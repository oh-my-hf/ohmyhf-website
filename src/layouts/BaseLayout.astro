---
import '../styles/global.css';
import { REPO_URL } from '../config';
import { htmlLang, localePath, useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  noIndex?: boolean;
  skipJsonLd?: boolean;
}

const {
  locale,
  title: titleOverride,
  description: descriptionOverride,
  noIndex = false,
  skipJsonLd = false,
} = Astro.props;
const t = useTranslations(locale);
const lang = htmlLang(locale);
const canonicalPath = localePath(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const site = Astro.site ?? new URL('https://ohmyhf.com');
const canonicalURL = new URL(canonicalPath, site);
const title = titleOverride ?? t('meta.title');
const description = descriptionOverride ?? t('meta.description');
const ogLocale = locale === 'zh-CN' ? 'zh_CN' : 'en_US';
const ogLocaleAlt = locale === 'zh-CN' ? 'en_US' : 'zh_CN';
const ogImage = new URL('/og.png', site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'ohmyhf',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Windows, Linux',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  url: site.href,
  downloadUrl: `${REPO_URL}/releases`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!doctype html>
<html lang={lang} class="bg-ink" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    {noIndex ? <meta name="robots" content="noindex, follow" /> : null}
    <script is:inline>
      (() => {
        let theme;
        try {
          theme = localStorage.getItem('theme');
        } catch {
          /* storage unavailable */
        }
        if (theme !== 'light' && theme !== 'dark') {
          theme = 'light';
        }
        document.documentElement.dataset.theme = theme;
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', theme === 'light' ? '#ffffff' : '#070b14');
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      noIndex ? null : (
        <>
          <link rel="canonical" href={canonicalURL.href} />
          <link rel="alternate" hreflang="en" href={new URL('/', site).href} />
          <link rel="alternate" hreflang="zh-CN" href={new URL('/zh/', site).href} />
          <link rel="alternate" hreflang="x-default" href={new URL('/', site).href} />
        </>
      )
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ohmyhf" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="ohmyhf — the Hugging Face desktop client that should have existed. Unofficial, open source."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${base}/favicon-192.png`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    {
      skipJsonLd ? null : (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body class="bg-ink text-body min-h-screen">
    <slot />
  </body>
</html>
